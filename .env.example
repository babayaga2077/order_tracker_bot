# Bot token issued by @BotFather
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# Your Telegram chat_id — where status-change notifications are sent.
# How to find it: send the bot any message once, then open
# https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates
# and look for the "chat": {"id": ...} field — that's your chat_id.
# Or just send /start to @userinfobot — it will show you your id.
TELEGRAM_CHAT_ID=

# 17TRACK API key for universal parcel tracking by tracking number.
# Sign up (free, 100 tracking numbers/month): https://www.17track.net/en/api
# Key location: Settings -> Security -> Access Key
TRACK17_API_KEY=

# Path to the SQLite database file (stores the order list managed via the
# bot's /add & /remove commands, plus the last known status of each order)
DB_PATH=orders.db

# How often the bot re-checks all orders in the background, in minutes
CHECK_INTERVAL_MINUTES=30

# Path to the saved session (cookies) for the store order-status adapter,
# see providers/store_generic.py. Leave empty if you don't use it.
GENERIC_STORE_STATE_PATH=
